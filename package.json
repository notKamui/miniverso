{
  "name": "miniverso",
  "version": "1.11.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env-shell NODE_ENV=development \"bun scripts/migrate.ts && vite dev --port 3000\"",
    "start": "bun run --env-file=.env serve.js",
    "b": "bun run build",
    "build": "cross-env NODE_ENV=production BUILD_ENV=production vite build --mode production",
    "build:entrypoint": "bun build --minify --target=bun --outfile=dist/serve.js --packages=external scripts/serve.ts",
    "postbuild": "bun run build:entrypoint",
    "test": "bun -b vitest",
    "test:run": "bun -b vitest run",
    "t": "bun test:run",
    "lint": "bunx -b oxlint --type-aware --deny-warnings",
    "lint:no-types": "bunx -b oxlint --deny-warnings",
    "fmt": "oxfmt",
    "type-check": "tsgo --noEmit",
    "tc": "bun type-check",
    "fix": "bun fmt && bun lint --fix",
    "check": "bun run --parallel --no-exit-on-error --filter '*' 'check:*'",
    "check:lint": "bun lint",
    "check:fmt": "bun fmt --check",
    "check:tc": "bun type-check",
    "dev:docker": "docker compose -f docker-compose.dev.yml",
    "db": "drizzle-kit",
    "migrate": "bun db migrate",
    "auth:secret": "bunx @better-auth/cli@latest secret",
    "auth:generate": "bunx @better-auth/cli@latest generate --y --output ./src/server/db/schema/auth.ts && bun run fix",
    "deploy": "sh ./deployment/_.deploy.sh",
    "up": "bunx -b taze@latest major -lI"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@better-auth-ui/core": "^1.6.3",
    "@better-auth-ui/react": "^1.6.3",
    "@better-auth/passkey": "^1.6.5",
    "@epic-web/client-hints": "^1.3.9",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-core": "^5.99.2",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-pacer": "^0.22.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.42",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.5",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "recharts": "3.8.1",
    "resend": "^6.12.0",
    "sonner": "^2.0.7",
    "srvx": "^0.11.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.21",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.22",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "4.1.4",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.10",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "react-is": "19.2.5"
  },
  "engines": {
    "bun": ">=1.3.12",
    "node": ">=25"
  },
  "_notes": {}
}
