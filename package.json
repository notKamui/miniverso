{
  "name": "miniverso",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env-shell NODE_ENV=development \"bun scripts/migrate.ts && vite dev --port 3000\"",
    "start": "bun run --env-file=.env serve.js",
    "b": "bun run build",
    "build": "cross-env NODE_ENV=production BUILD_ENV=production vite build --mode production",
    "build:entrypoint": "bun build --minify --target=bun --outfile=dist/serve.js --packages=external scripts/serve.ts",
    "postbuild": "bun run build:entrypoint",
    "test": "bun -b vitest",
    "test:run": "bun -b vitest run",
    "t": "bun test:run",
    "lint": "bunx -b oxlint --type-aware --deny-warnings",
    "lint:no-types": "bunx -b oxlint --deny-warnings",
    "fmt": "oxfmt",
    "type-check": "tsgo --noEmit",
    "tc": "bun type-check",
    "fix": "bun fmt && bun lint --fix",
    "check": "bun run --parallel --no-exit-on-error check:*",
    "check:lint": "bun lint",
    "check:fmt": "bun fmt --check",
    "check:tc": "bun type-check",
    "dev:docker": "docker compose -f docker-compose.dev.yml",
    "db": "drizzle-kit",
    "migrate": "bun db migrate",
    "auth:secret": "bunx @better-auth/cli@latest secret",
    "auth:generate": "bunx @better-auth/cli@latest generate --y --output ./src/server/db/schema/auth.ts && bun run fix",
    "deploy": "sh ./deployment/_.deploy.sh",
    "up": "bunx -b taze@latest major -lI"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@daveyplate/better-auth-tanstack": "^1.3.6",
    "@daveyplate/better-auth-ui": "^3.3.15",
    "@epic-web/client-hints": "^1.3.8",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "2.15.4",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.5.3",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.161.4",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-form-devtools": "^0.2.17",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260307.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "4.0.18",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.9",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vite": "8.0.0-beta.16",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "8.0.0-beta.16"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=25"
  },
  "_notes": {}
}
