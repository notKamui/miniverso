{
  "name": "miniverso",
  "version": "1.12.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env-shell NODE_ENV=development \"node --experimental-strip-types scripts/migrate-run.ts && vite dev --port 3000\"",
    "start": "cross-env NODE_ENV=production node --env-file=.env dist/serve.js",
    "b": "pnpm build",
    "build": "cross-env NODE_ENV=production BUILD_ENV=production vite build --mode production",
    "test": "vitest --typecheck",
    "test:run": "vitest run --typecheck",
    "t": "pnpm test:run",
    "lint": "oxlint --type-aware --deny-warnings",
    "lint:no-types": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "type-check": "tsgo --noEmit",
    "tc": "pnpm type-check",
    "fix": "pnpm fmt && pnpm lint --fix",
    "check": "pnpm run \"/^check:.*/\"",
    "check:lint": "pnpm lint",
    "check:fmt": "pnpm fmt --check",
    "check:tc": "pnpm type-check",
    "dev:docker": "docker compose -f docker-compose.dev.yml",
    "db": "drizzle-kit",
    "migrate": "pnpm db migrate",
    "auth:secret": "pnpx @better-auth/cli@latest secret",
    "auth:generate": "pnpx @better-auth/cli@latest generate --y --output ./src/server/db/schema/auth.ts && pnpm run fix",
    "deploy": "sh ./deployment/_.deploy.sh",
    "up": "pnpx taze@latest major -lI"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth-ui/core": "^1.6.3",
    "@better-auth-ui/react": "^1.6.3",
    "@better-auth/passkey": "^1.6.9",
    "@epic-web/client-hints": "^1.3.9",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-core": "^5.100.6",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-pacer": "^0.22.0",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.9",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "recharts": "3.8.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "srvx": "^0.11.15",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-query-devtools": "^5.100.6",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.28",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "4.1.5"
  },
  "overrides": {
    "react-is": "19.2.5"
  },
  "engines": {
    "node": ">=24"
  },
  "_notes": {}
